{
    "compilerOptions": {
        "baseUrl": ".",
        "inlineSourceMap": true,
        "inlineSources": true,
        "module": "ESNext",
        "target": "es2016",
        "allowJs": true,
        "noImplicitAny": true,
        "moduleResolution": "node",
        "importHelpers": true,
        "lib": [
            "dom",
            "es2016",
            "scripthost",
            "es2015"
        ],
        "typeRoots": [
          "src",
          "node_modules/@types"
        ]
    },
    "include": [
        "**/*.ts"
    ]
}